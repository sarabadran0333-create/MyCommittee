@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<MyCommittee.Models.Calendar>

@section Styles {
    <style>
        .page-shell {
            padding-top: 8px;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .page-subtitle {
            color: #64748b;
            font-size: 1.1rem;
            margin-bottom: 28px;
        }

        .stats-row {
            display: flex;
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            flex: 1;
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 26px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .stat-label {
            color: #475569;
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 2.2rem;
            line-height: 1;
            font-weight: 700;
            color: #0f172a;
        }

        .stat-icon {
            width: 54px;
            height: 54px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
        }

        .icon-blue {
            background: #eef2ff;
            color: #3b6ef5;
        }

        .icon-green {
            background: #ecfdf3;
            color: #16a34a;
        }

        .icon-yellow {
            background: #fff7ed;
            color: #f59e0b;
        }

        .icon-red {
            background: #fef2f2;
            color: #ef4444;
        }

        .section-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 24px 28px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
            margin-bottom: 28px;
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 18px;
        }

        .activity-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 0;
        }

        .activity-table thead th {
            text-align: left;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
            padding: 12px 10px 14px 10px;
            border-bottom: 1px solid #dbe3ef;
        }

        .activity-table tbody td {
            padding: 14px 10px;
            border-bottom: 1px solid #e8eef5;
            color: #0f172a;
        }

        .activity-table tbody tr:last-child td {
            border-bottom: none;
        }

        .muted-time {
            color: #64748b;
        }

        .bottom-row {
            display: flex;
            gap: 28px;
        }

        .bottom-col {
            flex: 1;
        }

        .list-item-card {
            background: #f4f7fc;
            border-radius: 18px;
            padding: 18px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

        .list-item-card:last-child {
            margin-bottom: 0;
        }

        .list-item-title {
            margin: 0 0 4px 0;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
        }

        .list-item-subtitle {
            margin: 0;
            color: #64748b;
            font-size: 0.98rem;
        }

        .status-pill {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 999px;
            background: #dcfce7;
            color: #16a34a;
            font-weight: 600;
            font-size: 0.95rem;
        }
    </style>
}
<script>

    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.counter'); // class name must Be "counter"

        counters.forEach(counter => {
            const updateCount = () => {
                const target = +counter.getAttribute('data-target');
                const count = +counter.innerText;

                // سرعة العداد: كل ما صغر الرقم زادت السرعة
                const speed = 100;
                const increment = target / speed;

                if (count < target) {
                    counter.innerText = Math.ceil(count + increment);
                    setTimeout(updateCount, 70); // تحديث كل 100 مللي ثانية
                } else {
                    counter.innerText = target;
                }
            };
            updateCount();
        });
    });

</script>

<div class="page-shell">

    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome back, @HttpContextAccessor.HttpContext.Session.GetString("UserName")</p>

    <div class="stats-row">

    <div class="stat-card">
        <div>
            <div class="stat-label">My Committees</div>
                <div class="stat-value counter" id="committee-count" data-target="@ViewBag.CommitteesCount">0 </div>
        </div>
        <div class="stat-icon icon-blue">
            <i class="bi bi-people"></i>
        </div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Committee Members</div>
                <div class="stat-value counter" data-target="@ViewBag.TotalMembersCount">0</div>
        </div>
        <div class="stat-icon icon-green">
            <i class="bi bi-person-plus"></i>
        </div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Next Meetings</div>
                <div class="stat-value counter " data-target="@ViewBag.NextMeetingsCount">0</div>
        </div>
        <div class="stat-icon icon-yellow">
            <i class="bi bi-calendar-event"></i>
        </div>
    </div>

    <div class="stat-card">
        <div>
            <div class="stat-label">Pending Approvals</div>
            <div class="stat-value">5</div>
        </div>
        <div class="stat-icon icon-red">
            <i class="bi bi-check2-square"></i>
        </div>
    </div>

</div>


    

    <div class="section-card">
        <h3 class="section-title">Recent Activity</h3>

        <table class="activity-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Action</th>
                    <th>Committee</th>
                    <th>Date</th>
                </tr>
            </thead>
        <tbody>
            @if (ViewBag.RecentActivities != null)
            {
                foreach (var activity in ViewBag.RecentActivities)
                {
                    <tr>
                        @* ملاحظة: تأكدي أن أسماء الخصائص تطابق موديل Action عندك *@
                        <td>@activity.Member.Username</td> @* أو Username إذا قمتِ بربطه *@
                        <td>@activity.Details</td>
                        <td>@activity.Committee.Title</td>
                        <td>@activity.GetTimeAgo()</td>
                    </tr>
                }
            }


        </tbody>
        </table>
    </div>

    <div class="bottom-row">

        <div class="bottom-col">
            <div class="section-card">
                <h3 class="section-title">My Committees</h3>

                <div class="list-item-card">
                    <div>
                        <p class="list-item-title">Academic Affairs</p>
                    </div>
                    <span class="status-pill">Active</span>
                </div>

                <div class="list-item-card">
                    <div>
                        <p class="list-item-title">Research Committee</p>
                    </div>
                    <span class="status-pill">Active</span>
                </div>

                <div class="list-item-card">
                    <div>
                        <p class="list-item-title">Student Services</p>
                    </div>
                    <span class="status-pill">Active</span>
                </div>
            </div>
        </div>

        <div class="bottom-col">
            <div class="section-card">
                <h3 class="section-title">Upcoming Meetings</h3>

                <div class="list-item-card">
                    <div>
                        <p class="list-item-title">Budget Review</p>
                        <p class="list-item-subtitle">Feb 22, 2026 - 10:00 AM</p>
                    </div>
                </div>

                <div class="list-item-card">
                    <div>
                        <p class="list-item-title">Policy Discussion</p>
                        <p class="list-item-subtitle">Feb 23, 2026 - 2:00 PM</p>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>