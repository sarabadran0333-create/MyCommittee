@model dynamic
@{
    ViewData["Title"] = "My Committees";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}

@section Styles {
    <style>
        .page-shell {
            padding-top: 8px;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .page-subtitle {
            color: #64748b;
            font-size: 1.1rem;
            margin-bottom: 28px;
        }

        .table-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 22px 28px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
            max-width: 1080px;
        }

        .committee-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 0;
        }

        .committee-table thead th {
            text-align: left;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
            padding: 12px 10px 14px 10px;
            border-bottom: 1px solid #dbe3ef;
        }

        .committee-table tbody td {
            padding: 16px 10px;
            border-bottom: 1px solid #e8eef5;
            color: #0f172a;
            vertical-align: middle;
        }

        .committee-table tbody tr:last-child td {
            border-bottom: none;
        }

        .committee-name {
            font-weight: 600;
            color: #0f172a;
        }

        .category-pill {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 999px;
            background: #eef2ff;
            color: #3b6ef5;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .view-btn {
            background: #fff;
            border: 1px solid #dbe3ef;
            color: #0f172a;
            border-radius: 14px;
            padding: 8px 16px;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
        }

        .view-btn:hover {
            background: #f8fafc;
            color: #0f172a;
        }
    </style>
}

<div class="page-shell">

    <h1 class="page-title">My Committees</h1>
    <p class="page-subtitle">Committees assigned to you</p>

    <div class="table-card">
        <table class="committee-table">
            <thead>
                <tr>
                    <th>Committee Name</th>
                    <th>Category</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Members Count</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="committee-name">
                            @item.Title
                        </td>

                        <td>
                            <span class="category-pill">
                                @item.TypeId
                            </span>
                        </td>

                        <td>
                            @item.Start.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            @item.End.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            @item.MembersCount
                        </td>

                        <td>

                            <button class="view-btn"
                                    data-bs-toggle="modal"
                                    data-bs-target="#committeeModal-@item.CommitteeId">
                                View
                            </button>

                        </td>

                    </tr>

                    <!-- Modal -->
                    <div class="modal fade"
                         id="committeeModal-@item.CommitteeId"
                         tabindex="-1"
                         aria-hidden="true">

                        <div class="modal-dialog modal-lg modal-dialog-centered">

                            <div class="modal-content"
                                 style="border-radius:24px; border:none; padding:10px;">

                                <div class="modal-header border-0 pb-0">

                                    <h5 class="modal-title fw-semibold">
                                        Committee Details
                                    </h5>

                                    <button type="button"
                                            class="btn-close"
                                            data-bs-dismiss="modal">
                                    </button>

                                </div>

                                <div class="modal-body pt-3">

                                    <h5 class="fw-semibold mb-3">
                                        Members
                                    </h5>

                                    <ul class="list-group mb-4">

                                        @foreach (var member in item.Members)
                                        {
                                            <li class="list-group-item">
                                                @member
                                            </li>
                                        }

                                    </ul>

                                    <h5 class="fw-semibold mb-3">
                                        Permissions & Descriptions
                                    </h5>

                                    <div class="d-flex flex-column gap-3">

                                        @foreach (var permission in item.Permissions)
                                        {
                                            <div class="border rounded-4 p-3">

                                                <h6 class="fw-semibold mb-2 text-primary">
                                                    @permission.Title
                                                </h6>

                                                <p class="mb-0 text-muted">
                                                    @permission.Description
                                                </p>

                                            </div>
                                        }

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </tbody>

        </table>

    </div>

</div>