@{
    ViewData["Title"] = "Create Minutes";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}

@section Styles {

    <style>

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 32px;
            font-weight: 700;
            color: #0f172a;
        }

        .page-subtitle {
            color: #64748b;
            margin-top: 5px;
        }


        .form-card {
            background: white;
            padding: 35px;
            border-radius: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
        }


        .section-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 25px;
            color: #0f172a;
        }


        .input-group-custom {
            margin-bottom: 25px;
        }


            .input-group-custom label {
                display: block;
                margin-bottom: 10px;
                font-weight: 600;
                color: #334155;
            }


        .input-box {
            width: 100%;
            height: 55px;
            border: 1px solid #dbe3ef;
            border-radius: 14px;
            padding: 0 18px;
        }


        .textarea-box {
            width: 100%;
            min-height: 180px;
            border: 1px solid #dbe3ef;
            border-radius: 14px;
            padding: 18px;
        }


        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }


        .footer-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 30px;
        }


        .cancel-btn {
            background: #f1f5f9;
            border: none;
            padding: 14px 28px;
            border-radius: 14px;
            font-weight: 600;
        }


        .save-btn {
            background: #3b6ef5;
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 14px;
            font-weight: 600;
        }

            .save-btn:hover {
                background: #2f5ee0;
            }

    </style>

}



<div class="page-header">

    <div>

        <div class="page-title">

            Create Meeting Minutes

        </div>

        <div class="page-subtitle">

            Add meeting notes and discussion details

        </div>

    </div>

</div>



<div class="form-card">

    <div class="section-title">

        Minutes Information

    </div>


    <form>

        <div class="input-group-custom">

            <label>

                Meeting Title

            </label>

            <select class="input-box">

                <option>Budget Review Meeting</option>

                <option>Policy Discussion</option>

                <option>Research Updates</option>

            </select>

        </div>




        <div class="grid">

            <div class="input-group-custom">

                <label>

                    Committee

                </label>

                <input class="input-box"
                       value="Finance Committee" />

            </div>


            <div class="input-group-custom">

                <label>

                    Meeting Date

                </label>

                <input type="date"
                       class="input-box" />

            </div>

        </div>




        <div class="input-group-custom">

            <label>

                Attendees

            </label>

<textarea class="textarea-box"
          placeholder="Write attendees names..."></textarea>

        </div>




        <div class="input-group-custom">

            <label>

                Discussion Summary

            </label>

<textarea class="textarea-box"
          placeholder="Write discussion summary..."></textarea>

        </div>




        <div class="input-group-custom">

            <label>

                Decisions & Recommendations

            </label>

<textarea class="textarea-box"
          placeholder="Write recommendations..."></textarea>

        </div>



        <div class="footer-buttons">

            <button type="button"
                    class="cancel-btn">

                Cancel

            </button>


            <button type="submit"
                    class="save-btn">

                <i class="bi bi-check-circle"></i>

                Save Minutes

            </button>

        </div>

    </form>

</div>