@{
    ViewData["Title"] = "Tasks";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}

@section Styles {
    <style>
        .page-shell {
            padding-top: 8px;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .page-subtitle {
            margin: 0 0 28px 0;
            color: #64748b;
            font-size: 1.1rem;
        }

        .stats-row {
            display: flex;
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            flex: 1;
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 24px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .stat-title {
            color: #64748b;
            font-size: 1rem;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1;
        }

        .stat-value.default {
            color: #0f172a;
        }

        .stat-value.progress {
            color: #f59e0b;
        }

        .stat-value.completed {
            color: #16a34a;
        }

        .section-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 24px 28px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 22px;
        }

        .tasks-table {
            width: 100%;
            border-collapse: collapse;
        }

        .tasks-table thead th {
            text-align: left;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
            padding: 12px 10px 14px 10px;
            border-bottom: 1px solid #dbe3ef;
        }

        .tasks-table tbody td {
            padding: 18px 10px;
            border-bottom: 1px solid #e8eef5;
            color: #0f172a;
            vertical-align: middle;
        }

        .tasks-table tbody tr:last-child td {
            border-bottom: none;
        }

        .status-select {
            min-width: 170px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 0 14px;
            font-weight: 500;
            appearance: none;
            background-position: right 12px center;
            background-repeat: no-repeat;
            background-size: 16px;
            cursor: pointer;
        }

        .status-progress {
            background-color: #fff7ed;
            color: #f59e0b;
        }

        .status-pending {
            background-color: #f8fafc;
            color: #64748b;
        }

        .status-completed {
            background-color: #ecfdf3;
            color: #16a34a;
        }
    </style>
}

<div class="page-shell">

    <h1 class="page-title">Tasks</h1>
    <p class="page-subtitle">Track and manage assigned tasks</p>

    <div class="stats-row">

        <div class="stat-card">
            <div class="stat-title">Total Tasks</div>
            <div class="stat-value default">4</div>
        </div>

        <div class="stat-card">
            <div class="stat-title">In Progress</div>
            <div class="stat-value progress">2</div>
        </div>

        <div class="stat-card">
            <div class="stat-title">Completed</div>
            <div class="stat-value completed">1</div>
        </div>

    </div>

    <div class="section-card">
        <h3 class="section-title">All Tasks</h3>

        <table class="tasks-table">
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Assigned To</th>
                    <th>Deadline</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>Review budget proposal</td>
                    <td>Dr. Sarah Ahmed</td>
                    <td>2/24/2026</td>
                    <td>
                        <select class="status-select status-progress">
                            <option selected>In Progress</option>
                            <option>Pending</option>
                            <option>Completed</option>
                        </select>
                    </td>
                </tr>

                <tr>
                    <td>Update research guidelines</td>
                    <td>Prof. Mohammed Ali</td>
                    <td>2/26/2026</td>
                    <td>
                        <select class="status-select status-pending">
                            <option>In Progress</option>
                            <option selected>Pending</option>
                            <option>Completed</option>
                        </select>
                    </td>
                </tr>

                <tr>
                    <td>Prepare meeting agenda</td>
                    <td>Ms. Fatima Hassan</td>
                    <td>2/23/2026</td>
                    <td>
                        <select class="status-select status-completed">
                            <option>In Progress</option>
                            <option>Pending</option>
                            <option selected>Completed</option>
                        </select>
                    </td>
                </tr>

                <tr>
                    <td>Review policy draft</td>
                    <td>Mr. Ahmed Khan</td>
                    <td>2/25/2026</td>
                    <td>
                        <select class="status-select status-progress">
                            <option selected>In Progress</option>
                            <option>Pending</option>
                            <option>Completed</option>
                        </select>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>