@model List<MyCommittee.Models.TaskItem>
@{
    ViewData["Title"] = "Tasks";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}

@section Styles {
    <style>
        .page-shell {
            padding-top: 8px;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .page-subtitle {
            margin: 0 0 28px 0;
            color: #64748b;
            font-size: 1.1rem;
        }

        .stats-row {
            display: flex;
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            flex: 1;
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 24px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .stat-title {
            color: #64748b;
            font-size: 1rem;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1;
        }

        .stat-value.default {
            color: #0f172a;
        }

            .stat-value.in-progress {
                color: #2563eb;
                background: transparent;
            }
        .stat-value.completed {
            color: #16a34a;
                background: transparent;
        }

        .section-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 24px 28px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 22px;
        }

        .tasks-table {
            width: 100%;
            border-collapse: collapse;
        }

        .tasks-table thead th {
            text-align: left;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
            padding: 12px 10px 14px 10px;
            border-bottom: 1px solid #dbe3ef;
        }

        .tasks-table tbody td {
            padding: 18px 10px;
            border-bottom: 1px solid #e8eef5;
            color: #0f172a;
            vertical-align: middle;
        }

        .tasks-table tbody tr:last-child td {
            border-bottom: none;
        }

        .status-select {
            min-width: 170px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 0 14px;
            font-weight: 500;
            appearance: none;
            background-position: right 12px center;
            background-repeat: no-repeat;
            background-size: 16px;
            cursor: pointer;
        }

        .status-badge {
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 600;
            display: inline-block;
        }

        .in-progress {
            background-color: #dbeafe;
            color: #2563eb;
        }

        .completed {
            background-color: #dcfce7;
            color: #16a34a;
        }

        .overdue {
            background-color: #fee2e2;
            color: #dc2626;
        }

        .overdue {
            background: #ffe5e5;
            color: #dc2626;
        }
    </style>
}

<div class="page-shell">

    <h1 class="page-title">Tasks</h1>
    <p class="page-subtitle">Track and manage assigned tasks</p>

    <div class="stats-row">

        <div class="stat-card">
            <div class="stat-title">Total Tasks</div>
            <div class="stat-value default">
                @ViewBag.TotalTasks
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-title">In Progress</div>
            <div class="stat-value in-progress">
                @ViewBag.InProgressTasks
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-title">Completed</div>
            <div class="stat-value completed">
                @ViewBag.CompletedTasks
            </div>
        </div>

    </div>

    <div class="section-card">
        <h3 class="section-title">All Tasks</h3>

        <table class="tasks-table">
            <thead>
                <tr>
                    <th>Task</th>
                    <th>Assigned To</th>
                    <th>Deadline</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    string status = "";
                    string statusClass = "";

                    if (item.IsSubmitted)
                    {
                        status = "Completed";
                        statusClass = "completed";
                    }
                    else if (item.Deadline < DateTime.Now)
                    {
                        status = "Overdue";
                        statusClass = "overdue";
                    }
                    else
                    {
                        status = "In Progress";
                        statusClass = "in-progress";
                    }

                    <tr>
                        <td>@item.Task</td>

                        <td>@item.Member.Username</td>

                        <td>
                            @item.Deadline.ToShortDateString()
                        </td>

                        <td>
                            <span class="status-badge @statusClass">
                                @status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>