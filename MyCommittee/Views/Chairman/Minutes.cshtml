@{
    ViewData["Title"] = "Minutes";
    Layout = "~/Views/Shared/_ChairmanLayout.cshtml";
}

@section Styles {

    <style>

        .page-shell {
            padding-top: 8px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
        }

        .page-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 5px;
        }

        .page-subtitle {
            color: #64748b;
            font-size: 1rem;
        }


        .create-btn {
            background: #3b6ef5;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 14px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .create-btn:hover {
                background: #2f5ee0;
                color: white;
            }


        .minutes-wrap {
            background: white;
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
        }


        .minutes-table {
            width: 100%;
            border-collapse: collapse;
        }


            .minutes-table th {
                padding: 16px;
                border-bottom: 1px solid #e2e8f0;
                text-align: left;
                font-size: 15px;
                color: #475569;
            }


            .minutes-table td {
                padding: 18px 16px;
                border-bottom: 1px solid #e2e8f0;
                vertical-align: middle;
            }


        .minute-title {
            font-weight: 600;
        }


        .status {
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }


        .approved {
            background: #dcfce7;
            color: #16a34a;
        }


        .pending {
            background: #fff7ed;
            color: #f59e0b;
        }


        .action-btn {
            background: #eef2ff;
            padding: 10px 15px;
            border-radius: 12px;
            text-decoration: none;
            color: #3b6ef5;
            font-weight: 600;
        }


            .action-btn:hover {
                background: #dbe6ff;
                color: #3b6ef5;
            }

    </style>

}



<div class="page-shell">

    <div class="page-header">

        <div>

            <div class="page-title">

                Meeting Minutes

            </div>

            <div class="page-subtitle">

                Manage and review meeting minutes

            </div>

        </div>


        <a asp-controller="Chairman"
           asp-action="CreateMinutes"
           class="create-btn">

            <i class="bi bi-plus-circle"></i>

            Create Minutes

        </a>

    </div>




    <div class="minutes-wrap">

        <table class="minutes-table">

            <thead>

                <tr>

                    <th>Title</th>

                    <th>Committee</th>

                    <th>Date</th>

                    <th>Status</th>

                    <th>Actions</th>

                </tr>

            </thead>



            <tbody>

                <tr>

                    <td class="minute-title">

                        Budget Review Minutes

                    </td>

                    <td>

                        Finance Committee

                    </td>

                    <td>

                        22 Feb 2026

                    </td>

                    <td>

                        <span class="status approved">

                            Approved

                        </span>

                    </td>

                    <td>

                        <a asp-controller="Chairman"
                           asp-action="MinuteDetails"
                           class="action-btn">

                            <i class="bi bi-eye"></i>

                            View

                        </a>

                    </td>

                </tr>



                <tr>

                    <td class="minute-title">

                        Policy Discussion Notes

                    </td>

                    <td>

                        Academic Affairs

                    </td>

                    <td>

                        23 Feb 2026

                    </td>

                    <td>

                        <span class="status pending">

                            Pending

                        </span>

                    </td>

                    <td>

                        <a asp-controller="Chairman"
                           asp-action="MinuteDetails"
                           class="action-btn">

                            <i class="bi bi-eye"></i>

                            View

                        </a>

                    </td>

                </tr>



                <tr>

                    <td class="minute-title">

                        Research Updates

                    </td>

                    <td>

                        Research Committee

                    </td>

                    <td>

                        25 Feb 2026

                    </td>

                    <td>

                        <span class="status approved">

                            Approved

                        </span>

                    </td>

                    <td>

                        <a asp-controller="Chairman"
                           asp-action="MinuteDetails"
                           class="action-btn">

                            <i class="bi bi-eye"></i>

                            View

                        </a>

                    </td>

                </tr>

            </tbody>

        </table>

    </div>

</div>