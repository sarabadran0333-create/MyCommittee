@{
    ViewData["Title"] = "Meetings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- FullCalendar CSS & JS -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>


@section Styles {
    <style>
        .meetings-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
        }

        .meetings-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .meetings-subtitle {
            margin: 0;
            color: #64748b;
            font-size: 1.1rem;
        }

        .view-switch {
            display: inline-flex;
            align-items: center;
            background: #f1f5f9;
            border-radius: 16px;
            padding: 4px;
            gap: 4px;
        }

        .view-btn {
            border: none;
            background: transparent;
            color: #0f172a;
            font-weight: 500;
            padding: 10px 16px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .view-btn.active {
            background: white;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
        }

        .meetings-table-wrap {
            background: transparent;
            border-radius: 20px;
        }

        .meetings-table {
            width: 100%;
            border-collapse: collapse;
            background: transparent;
        }

        .meetings-table thead th {
            text-align: left;
            font-size: 1rem;
            font-weight: 600;
            color: #0f172a;
            padding: 10px 10px 14px 10px;
            border-bottom: 1px solid #dbe3ef;
        }

        .meetings-table tbody td {
            padding: 16px 10px;
            font-size: 1rem;
            color: #0f172a;
            border-bottom: 1px solid #dbe3ef;
            vertical-align: middle;
        }

        .meetings-table tbody tr:last-child td {
            border-bottom: none;
        }

        .meeting-title {
            font-weight: 500;
        }

        .action-btn {
            background: #3b6ef5;
            color: white;
            border: none;
            border-radius: 14px;
            padding: 10px 16px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .action-btn:hover {
            background: #2f5ee0;
            color: white;
        }

        .page-shell {
            padding-top: 8px;
        }

      
            .meetings-header {
                flex-direction: column;
                gap: 16px;
            }

            .table-responsive {
                overflow-x: auto;
            }

            .meetings-table {
                min-width: 950px;
            }
       
    </style>
}

<div class="page-shell">

    <div class="meetings-header">
        <div>
            <h1 class="meetings-title">Meetings</h1>
            <p class="meetings-subtitle">Schedule and manage committee meetings</p>
        </div>

        <div class="view-switch">
            <button type="button" class="view-btn active">
                <i class="bi bi-list-ul"></i>
                <span>List</span>
            </button>

            <button type="button" class="view-btn">
                <i class="bi bi-calendar3"></i>
                <span>Calendar</span>
            </button>
        </div>
    </div>

    <div class="meetings-table-wrap">
        <div class="table-responsive">
            <table class="meetings-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Committee</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Room</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="meeting-title">@item.MeetingTitle</td>
                            <td>@(item.Committee?.Title ?? "No Committee")</td>
                            <td>@item.MeetingTime.ToString("MM/dd/yyyy")</td>  
                            <td>@item.MeetingTime.ToString("hh:mm tt")</td>
                            <td>@item.Place</td>
                            <td>
                                <a asp-action="PrintMinutes" asp-route-id="@item.CalendarId" class="action-btn">
                                    <i class="bi bi-eye"></i>
                                    <span>View Details</span>
                                </a>
                            </td>
                        </tr>
                    } 
                </tbody>
            </table>
            
        </div>
    </div>
    <div id="calendar-view" style="display:none; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <div id="calendar"></div>
    </div>

</div>
<script>
    var calendar; // تعريف المتغير عالمياً

    document.addEventListener('DOMContentLoaded', function() {
        const listBtn = document.querySelectorAll('.view-btn')[0];
        const calendarBtn = document.querySelectorAll('.view-btn')[1];
        const tableView = document.querySelector('.meetings-table-wrap');
        const calendarView = document.getElementById('calendar-view');

        //  البيانات من الموديل
        const myEvents = [
            @foreach (var item in Model)
            {
                    <text>
                    {
                        id: '@item.CalendarId',
                        title: '@item.MeetingTitle',
                        start: '@item.MeetingTime.ToString("yyyy-MM-ddTHH:mm:ss")',
                        extendedProps: {
                            committee: '@(item.Committee?.Title ?? "N/A")',
                            room: '@item.Place'
                        },
                        backgroundColor: '#2563eb', // لون الإشارة على التاريخ
                        borderColor: '#1e40af'
                    },
                    </text>
            }
        ];

        // تهيئة التقويم ولكن لا نعرضه الآن
        var calendarEl = document.getElementById('calendar');
        calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek'
            },
            events: myEvents,
            // عند الضغط على الاجتماع تظهر تفاصيله (نفس الجدول)
            eventClick: function(info) {
                alert(
                    "Meeting: " + info.event.title +
                    "\nCommittee: " + info.event.extendedProps.committee +
                    "\nRoom: " + info.event.extendedProps.room +
                    "\nDate: " + info.event.start.toLocaleString()
                );
                // إذا أردتِ الانتقال لصفحة التفاصيل فوراً فكي التعليق عن السطر التالي:
                // window.location.href = '/Admin/MeetingMinutes/' + info.event.id;
            }
        });

        calendarBtn.addEventListener('click', function() {
            tableView.style.display = 'none';
            calendarView.style.display = 'block';
            calendarBtn.classList.add('active');
            listBtn.classList.remove('active');

            // سطر مهم جداً لإجبار التقويم على الرسم عند الظهور
            calendar.render();
        });

        listBtn.addEventListener('click', function() {
            calendarView.style.display = 'none';
            tableView.style.display = 'block';
            listBtn.classList.add('active');
            calendarBtn.classList.remove('active');
        });
            calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        displayEventTime: true, // لإظهار وقت الاجتماع بجانب العنوان
        eventTimeFormat: {
            hour: 'numeric',
            minute: '2-digit',
            meridiem: 'short'
        },
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,dayGridWeek'
        },
        events: myEvents, // البيانات القادمة من الـforeach

        // تحسين شكل الإشارة (Event)
        eventDidMount: function(info) {
                info.el.style.cursor = 'pointer'; // تغيير شكل الماوس ليد عند التمرير
                // إضافة Tooltip بسيط يظهر عند الوقوف بالماوس
                info.el.title = "Committee: " + info.event.extendedProps.committee;
            },

            // عند الضغط على الموعد في التقويم
            eventClick: function(info) {
                // بدلاً من الـ Alert، سنستخدم الـ Modal الذي جهزناه سابقاً
                document.getElementById('modalTitle').innerText = info.event.title;
                document.getElementById('modalCommittee').innerText = info.event.extendedProps.committee;
                document.getElementById('modalRoom').innerText = info.event.extendedProps.room;
                document.getElementById('modalDate').innerText = info.event.start.toLocaleString();

                // ربط زر "View Minutes" بالصفحة الصحيحة
                document.getElementById('modalLink').href = '/Admin/MeetingMinutes/' + info.event.id;

                var myModal = new bootstrap.Modal(document.getElementById('meetingModal'));
                myModal.show();
            }
        });
    });

</script>