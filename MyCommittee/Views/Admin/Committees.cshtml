@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Committees";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .page-shell {
            padding-top: 8px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
        }

        .page-title {
            font-size: 2.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .page-subtitle {
            margin: 0;
            color: #64748b;
            font-size: 1.1rem;
        }

        .create-btn {
            background: #3b6ef5;
            color: white;
            border: none;
            border-radius: 18px;
            padding: 12px 20px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .create-btn:hover {
                background: #2f5ee0;
                color: white;
            }

        .panel-card {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.03);
        }

        .toolbar {
            display: grid;
            grid-template-columns: 1fr 260px;
            gap: 20px;
            margin-bottom: 26px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap i {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                color: #64748b;
                pointer-events: none;
            }

        .left-icon {
            left: 14px;
        }

        .right-icon {
            right: 14px;
        }

        .toolbar-input,
        .toolbar-select {
            height: 54px;
            border: 1px solid #dbe3ef;
            border-radius: 16px;
            font-size: 1rem;
            color: #0f172a;
            background: #fff;
        }

        .toolbar-input {
            padding-left: 42px;
        }

        .toolbar-select {
            padding-left: 16px;
            padding-right: 42px;
            appearance: none;
        }

            .toolbar-input:focus,
            .toolbar-select:focus {
                border-color: #3b6ef5;
                box-shadow: 0 0 0 0.15rem rgba(59, 110, 245, 0.12);
            }

        .committee-table {
            width: 100%;
            border-collapse: collapse;
        }

            .committee-table thead th {
                text-align: left;
                font-size: 1rem;
                font-weight: 600;
                color: #0f172a;
                padding: 12px 10px 14px 10px;
                border-bottom: 1px solid #dbe3ef;
            }

            .committee-table tbody td {
                padding: 18px 10px;
                border-bottom: 1px solid #e8eef5;
                color: #0f172a;
                vertical-align: middle;
            }

            .committee-table tbody tr:last-child td {
                border-bottom: none;
            }

        .committee-name {
            font-weight: 500;
        }

        .category-pill {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 999px;
            background: #eef2ff;
            color: #3b6ef5;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .action-btn {
            border: none;
            background: transparent;
            font-size: 1.05rem;
            margin-right: 16px;
            padding: 0;
        }

            .action-btn.edit {
                color: #334155;
            }

            .action-btn.delete {
                color: #ef4444;
                margin-right: 0;
            }

            .action-btn:hover {
                opacity: .75;
            }


        .page-header {
            flex-direction: column;
            gap: 16px;
        }

        .toolbar {
            grid-template-columns: 1fr;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .committee-table {
            min-width: 900px;
        }
    </style>
}

<div class="page-shell">

    <div class="page-header">
        <div>
            <h1 class="page-title">Committees</h1>
            <p class="page-subtitle">Manage all university committees</p>
        </div>

        <button class="create-btn" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg"></i>
            <span>Create Committee</span>
        </button>
    </div>

    <div class="panel-card">

        <div class="toolbar">
            

            <div class="input-wrap">
                <select id="typeFilter" class="form-select toolbar-select" onchange="filterTable()">
                    <option value="">All Committee Types</option>
                    @foreach (var t in ViewBag.CommitteeTypes)
                    {
                        <option value="@t.Name">@t.Name</option>
                    }
                </select>
                <i class="bi bi-chevron-down right-icon"></i>
            </div>
        </div>

        <div class="table-responsive">
            <table class="committee-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Committee Type</th>
                        <th>Leader</th>
                        <th>Members</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-type="@item.TypeName">
                            
                            <td class="committee-name">@item.Title</td>

                            
                            <td>
                                <span class="category-pill">
                                    @item.TypeName
                                </span>
                            </td>

                           
                            <td>@item.Leader</td>

                            
                            <td>@item.MembersCount</td>

                            
                            <td class="text-end">
                                <button class="action-btn edit"
                                        onclick="openEdit(@item.CommitteeId, '@item.Title', '@item.TypeId', '@item.LeaderId', '@item.Start', '@item.End', '@string.Join("|", item.Permissions)', '@string.Join("|", item.Descriptions)', '@string.Join(",", item.MemberIds)')">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="action-btn delete" onclick="deleteCommittee(@item.CommitteeId)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                 </tbody>
            </table>
        </div>

    </div>

</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:20px; border:none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold">Create Committee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-3">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="Title" class="form-control" placeholder="Enter committee title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Committee Type</label>

                    <select name="TypeId" class="form-select">
                        <option value="">Select committee type</option>

                        @foreach (var cat in ViewBag.CommitteeTypes)
                        {
                            <option value="@cat.TypeId">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Leader</label>

                    <select name="Leader" class="form-select">
                        <option value="">Select Leader</option>

                        @foreach (var member in ViewBag.Leaders)
                        {
                            <option value="@member.JobId">
                                @member.Username
                            </option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Number Of Members</label>

                    <div style="display:flex; gap:10px; align-items:center;">

                        <input type="number"  name="MembersCount" value="1" min="1" max="1000"   class="form-control" style="width:100px;" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Period</label>
                    <div style="display:flex; gap:10px;">
                        <input type="date" name="Start" class="form-control" />
                        <input type="date" name="End" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Permissions And Descriptions</label>

                        <div id="permissionsContainer"></div>

                        <button type="button" class="btn btn-light mt-2" onclick="addPermission()">
                            Add permission and description
                        </button>
                    </div>
              
            </div>

            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="goToMembers()">Next</button>
            </div>
        </div>
    </div>
</div>
<!--add members name-->
<div class="modal fade" id="membersModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" action="/Admin/SaveCommittee">
        <div class="modal-content" style="border-radius:20px; border:none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold">Committee Members Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-3">
                    <input type="hidden" id="hiddenTitle" name="Title" />
                    <input type="hidden" id="hiddenType" name="TypeId" />
                    <input type="hidden" id="hiddenCount" name="MembersCount" />
                    <input type="hidden" id="hiddenStart" name="Start" />
                    <input type="hidden" id="hiddenEnd" name="End" />
                    <input type="hidden" id="hiddenLeader" name="Leader" />

                <div class="mb-3">
                    <label class="form-label">Enter Members Name</label>
                    
                </div>
                <div id="membersContainer"></div>
                    <div id="hiddenPermissionsContainer"></div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" onclick="addNewMember()">Add member</button>               
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<!-- Edit Modal Step 1 -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:20px; border:none;">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold">Edit Committee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-3">

                <input type="hidden" id="editId" />

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input id="editTitle" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Committee Type</label>
                    <select id="editCommitteeType" class="form-select">
                        
                        @foreach (var cat in ViewBag.CommitteeTypes)
                        {
                            <option value="@cat.TypeId">@cat.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Leader</label>

                    <select id="editLeader" class="form-select">

                        @foreach (var member in ViewBag.Leaders)
                        {
                            <option value="@member.JobId">
                                @member.Username
                            </option>
                        }

                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Period</label>
                    <div style="display:flex; gap:10px;">
                        <input type="date" id="editStart" class="form-control" />
                        <input type="date" id="editEnd" class="form-control" />
                    </div>
                </div>

               
                    <div class="mb-3">
                        <label class="form-label">Permissions And Descriptions</label>

                        <div id="editPermissionsContainer"></div>

                        <button type="button" class="btn btn-light mt-2" onclick="addEditPermission()">
                            Add permission and description
                        </button>
                    </div>
                

            </div>

            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="goToEditMembers()">Next</button>
            </div>

        </div>
    </div>
</div>
<!--edit members-->
<!-- Edit Members Modal -->
<div class="modal fade" id="editMembersModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">

        <form method="post" action="/Admin/UpdateCommittee">

            <div class="modal-content" style="border-radius:20px; border:none;">

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-semibold">Edit Members</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body pt-3">

                    <!-- hidden -->
                    <input type="hidden" id="editIdHidden" name="CommitteeId" />
                    <input type="hidden" id="editTitleHidden" name="Title" />
                    <input type="hidden" id="editTypeHidden" name="TypeId" />
                    <input type="hidden" id="editLeaderHidden" name="Leader" />
                    <input type="hidden" id="editStartHidden" name="Start" />
                    <input type="hidden" id="editEndHidden" name="End" />

                    <div id="editMembersContainer"></div>
                    <div id="editHiddenPermissionsContainer"></div>

                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" onclick="addEditMember()">Add member</button>
                    <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>

            </div>

        </form>

    </div>
</div>
<!--modal to another modal-->
<script>

    document.getElementById('addModal')
        .addEventListener('shown.bs.modal', function () {

            let container = document.getElementById("permissionsContainer");

            if (container.children.length === 0) {

                addPermission();
            }
        });

</script>
<script>
    function goToMembers() {
        let title = document.querySelector('input[name="Title"]').value;
        let committeeType = document.querySelector('select[name="TypeId"]').value;
        let count = document.querySelector('input[name="MembersCount"]').value;
        let start = document.querySelector('input[name="Start"]').value;
        let end = document.querySelector('input[name="End"]').value;
    let leader = document.querySelector('select[name="Leader"]').value;
        if (!committeeType) {
            alert("Please select committee type");
            return;
        }

        document.getElementById("hiddenTitle").value = title;
        document.getElementById("hiddenType").value = committeeType;
        document.getElementById("hiddenCount").value = count;
        document.getElementById("hiddenStart").value = start;
        document.getElementById("hiddenEnd").value = end;
        document.getElementById("hiddenLeader").value = leader;
            let permissionsInputs =
        document.querySelectorAll('#permissionsContainer input[name="Permissions"]');
            let descriptionInputs =
    document.querySelectorAll('#permissionsContainer input[name="Descriptions"]');

    let hiddenPermissionsContainer =
        document.getElementById("hiddenPermissionsContainer");

    hiddenPermissionsContainer.innerHTML = "";

    permissionsInputs.forEach(p => {

        hiddenPermissionsContainer.innerHTML += `

            <input type="hidden"
                   name="Permissions"
                   value="${p.value}" />
        `;
    });
        descriptionInputs.forEach(d => {

        hiddenPermissionsContainer.innerHTML += `

            <input type="hidden"
                   name="Descriptions"
                   value="${d.value}" />
        `;
    });

        let container = document.getElementById("membersContainer");
        container.innerHTML = "";

        for (let i = 0; i < count; i++) {
            addMemberField(container);
        }

        bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();
        new bootstrap.Modal(document.getElementById('membersModal')).show();
    }
    function addMemberField(container) {

        let div = document.createElement("div");

        div.classList.add("mb-2", "d-flex", "align-items-center", "gap-2");

        div.innerHTML = `
            <select name="Members" class="form-select">

                <option value="">Select Member</option>

                @foreach (var member in ViewBag.Members)
                {
                        <option value="@member.JobId">
                            @member.Username
                        </option>
                }

            </select>

            <button type="button"
                    class="action-btn delete"
                    onclick="this.parentElement.remove()">

                <i class="bi bi-trash"></i>

            </button>
        `;

        container.appendChild(div);
    }

    function addNewMember() {
        addMemberField(document.getElementById("membersContainer"));
    }
</script>

<script>
    function addPermission() {
        let container = document.getElementById("permissionsContainer");

        let div = document.createElement("div");
        div.classList.add("mb-2", "d-flex", "gap-2");

            div.innerHTML = `

        <div style="width:100%;">

            <input type="text"
                   name="Permissions"
                   class="form-control mb-2"
                   placeholder="Permission" />

            <input type="text"
                   name="Descriptions"
                   class="form-control"
                   placeholder="Description" />

        </div>

        <button type="button"
                class="action-btn delete"
                onclick="this.parentElement.remove()">

            <i class="bi bi-trash"></i>

        </button>
    `;

        container.appendChild(div);
    }
</script>

<script>

    function openEdit(id, title, typeId, leaderId, start, end, permissions, descriptions, members) {

        document.getElementById("editId").value = id;

        document.getElementById("editTitle").value = title;

        document.getElementById("editCommitteeType").value = typeId;

        document.getElementById("editLeader").value = leaderId;

        document.getElementById("editStart").value =
            new Date(start).toISOString().split('T')[0];

        document.getElementById("editEnd").value =
            new Date(end).toISOString().split('T')[0];




        let permissionsContainer = document.getElementById("editPermissionsContainer");

        permissionsContainer.innerHTML = "";

        if (permissions) {

    let permissionList = permissions.split("|");

    let descriptionList = descriptions
        ? descriptions.split("|")
        : [];
        permissionList.forEach((p, index) => {
                    permissionsContainer.innerHTML += `

        <div class="mb-2 d-flex gap-2">

            <div style="width:100%;">

                <input type="text"
                       name="Permissions"
                       class="form-control mb-2"
                       value="${p}" />

                <input type="text"
                       name="Descriptions"
                       class="form-control"
                       value="${descriptionList[index] ?? ''}" />

            </div>

            <button type="button"
                    class="action-btn delete"
                    onclick="this.parentElement.remove()">

                <i class="bi bi-trash"></i>

            </button>

        </div>
    `;
            });
        }



        // members

        let membersContainer = document.getElementById("editMembersContainer");

        membersContainer.innerHTML = "";

        if (members) {

            let memberList = members.split(",");

            memberList.forEach(memberId => {

                membersContainer.innerHTML += `

                    <div class="mb-2 d-flex gap-2">

                        <select name="Members" class="form-select">

                            <option value="">Select Member</option>

                            @foreach (var member in ViewBag.Members)
                            {
                                    <option value="@member.JobId">
                                        @member.Username
                                    </option>
                            }

                        </select>

                        <button type="button"
                                class="action-btn delete"
                                onclick="this.parentElement.remove()">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>
                `;
            });

            let selects = membersContainer.querySelectorAll("select");

            selects.forEach((s, index) => {

                s.value = memberList[index];

            });
        }



        let modal = new bootstrap.Modal(
            document.getElementById('editModal')
        );

        modal.show();
    }

</script>

<script>
    function goToEditMembers() {
        document.getElementById("editIdHidden").value = document.getElementById("editId").value;
        document.getElementById("editTitleHidden").value = document.getElementById("editTitle").value;
        document.getElementById("editTypeHidden").value = document.getElementById("editCommitteeType").value;
        document.getElementById("editLeaderHidden").value = document.getElementById("editLeader").value;
        document.getElementById("editStartHidden").value = document.getElementById("editStart").value;
        document.getElementById("editEndHidden").value = document.getElementById("editEnd").value;
            let permissionsInputs =
        document.querySelectorAll('#editPermissionsContainer input[name="Permissions"]');
            let descriptionInputs =
    document.querySelectorAll('#editPermissionsContainer input[name="Descriptions"]');

      let editHiddenPermissionsContainer =
        document.getElementById("editHiddenPermissionsContainer");

    editHiddenPermissionsContainer.innerHTML = "";

    permissionsInputs.forEach(p => {

    editHiddenPermissionsContainer.innerHTML += `
            <input type="hidden"
                   name="Permissions"
                   value="${p.value}" />
        `;
    });
        descriptionInputs.forEach(d => {

        editHiddenPermissionsContainer.innerHTML += `

            <input type="hidden"
                   name="Descriptions"
                   value="${d.value}" />
        `;
    });

        bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
        new bootstrap.Modal(document.getElementById('editMembersModal')).show();
    }
</script>
<script>
       function addEditMember() {

        let container = document.getElementById("editMembersContainer");

    container.insertAdjacentHTML('beforeend', `
            <div class="mb-2 d-flex gap-2">

                <select name="Members" class="form-select">

                    <option value="">Select Member</option>

                    @foreach (var member in ViewBag.Members)
                    {
                            <option value="@member.JobId">
                                @member.Username
                            </option>
                    }

                </select>

                <button type="button"
                        class="action-btn delete"
                        onclick="this.parentElement.remove()">

                    <i class="bi bi-trash"></i>

                </button>

            </div>
        `);
    }
</script>
<script>
    function addEditPermission() {
        let container = document.getElementById("editPermissionsContainer");

           container.insertAdjacentHTML('beforeend', `

        <div class="mb-2 d-flex gap-2">

            <div style="width:100%;">

                <input type="text"
                       name="Permissions"
                       class="form-control mb-2"
                       placeholder="Permission" />

                <input type="text"
                       name="Descriptions"
                       class="form-control"
                       placeholder="Description" />

            </div>

            <button type="button"
                    class="action-btn delete"
                    onclick="this.parentElement.remove()">

                <i class="bi bi-trash"></i>

            </button>

        </div>

    `);
    }
</script>

<script>
    function deleteCommittee(id) {
        if (!confirm("Are you sure?")) return;

        fetch('/Admin/DeleteCommittee/' + id, {
            method: 'POST'
        })
        .then(() => location.reload());
    }
</script>
<script>
    function filterTable() {
        let selected = document.getElementById("typeFilter").value.toLowerCase();
        let rows = document.querySelectorAll(".committee-table tbody tr");

        rows.forEach(row => {
            let type = row.getAttribute("data-type").toLowerCase();

            if (selected === "" || type === selected) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }
</script>