@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyCommittee</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #4f46e5;
            --primary-dark: #3730a3;
            --secondary: #10b981;
            --danger: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-600: #4b5563;
            --gray-900: #111827;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--gray-50);
            margin: 0;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            height: 100vh;
            position: fixed;
            background: white;
            border-right: 1px solid var(--gray-200);
            box-shadow: 2px 0 8px rgba(0,0,0,0.05);
        }

        .sidebar-header {
            padding: 24px;
            border-bottom: 1px solid var(--gray-200);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 20px;
            margin: 5px 15px;
            border-radius: 8px;
            color: var(--gray-600);
            text-decoration: none;
        }

            .nav-link:hover {
                background: var(--gray-100);
                color: var(--gray-900);
            }

            .nav-link.active {
                background: var(--primary);
                color: white;
            }

        .main-content {
            margin-left: 280px;
            padding: 30px;
        }

        

        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">

        <div class="sidebar-header">
            <div class="user-info">
                <div class="user-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <div class="fw-bold">@User.Identity?.Name</div>

                    @if (User.IsInRole("Admin"))
                    {
                        <small class="text-muted">Admin</small>
                    }
                    else if (User.IsInRole("Chairman"))
                    {
                        <small class="text-muted">Chairman</small>
                    }
                    else
                    {
                        <small class="text-muted">User</small>
                    }
                </div>
            </div>
        </div>

        <!-- Menu -->
        <nav>

            <a asp-controller="Admin" asp-action="Dashboard"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>

            <a asp-controller="Admin" asp-action="Committees"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Committees" ? "active" : "")">
                <i class="fas fa-users"></i> Committees
            </a>

            <a asp-controller="Admin" asp-action="Members"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Members" ? "active" : "")">
                <i class="fas fa-user-friends"></i> Members
            </a>

            <a asp-controller="Admin" asp-action="Meetings"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Meetings" ? "active" : "")">
                <i class="fas fa-calendar-alt"></i> Meetings
            </a>

            <a asp-controller="Admin" asp-action="Minutes"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Minutes" ? "active" : "")">
                <i class="fas fa-file-alt"></i> Minutes
            </a>

            <a asp-controller="Admin" asp-action="Tasks"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Tasks" ? "active" : "")">
                <i class="fas fa-check-square"></i> Tasks
            </a>

            <a asp-controller="Admin" asp-action="Archive"
               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Archive" ? "active" : "")">
                <i class="fas fa-archive"></i> Archive
            </a>

            <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>

        </nav>

    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>